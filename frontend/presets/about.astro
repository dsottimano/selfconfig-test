---
// "About" page template (preset). A complete, designed page — the owner picks it
// and edits only the slots declared in about.slots.json; the layout is untouchable.
// Slots are freeform CMS content, so read defensively and let Astro auto-escape
// text (a rich-HTML slot would route through lib/sanitize like the page body).
interface Props {
  slots?: Record<string, unknown>;
}

const { slots = {} } = Astro.props;
const s = slots as Record<string, any>;

const stats: { value?: string; label?: string }[] = Array.isArray(s.stats) ? s.stats : [];
const hasCta = s.ctaHeading || s.ctaButtonText;

function safeHref(url: unknown): string {
  const u = typeof url === "string" ? url : "";
  if (/^(https?:|mailto:|tel:)/i.test(u)) return u;
  if (u.startsWith("/") && !u.startsWith("//")) return u;
  return "#";
}
---

<section class="p-about">
  <header class="p-about__hero">
    {s.eyebrow && <p class="p-about__eyebrow">{s.eyebrow}</p>}
    <h1 class="p-about__headline">{s.headline}</h1>
    {s.subheading && <p class="p-about__sub">{s.subheading}</p>}
  </header>

  {
    (s.storyHeading || s.storyBody) && (
      <div class="p-about__story">
        {s.storyHeading && <h2>{s.storyHeading}</h2>}
        {s.storyBody &&
          String(s.storyBody)
            .split(/\n{2,}/)
            .map((para) => <p>{para}</p>)}
      </div>
    )
  }

  {
    stats.length > 0 && (
      <ul class="p-about__stats">
        {stats.map((stat) => (
          <li>
            <span class="p-about__stat-value">{stat.value}</span>
            <span class="p-about__stat-label">{stat.label}</span>
          </li>
        ))}
      </ul>
    )
  }

  {
    hasCta && (
      <div class="p-about__cta">
        {s.ctaHeading && <h2>{s.ctaHeading}</h2>}
        {s.ctaText && <p>{s.ctaText}</p>}
        {s.ctaButtonText && (
          <a class="button" href={safeHref(s.ctaButtonUrl)}>
            {s.ctaButtonText}
          </a>
        )}
      </div>
    )
  }
</section>

<style>
  .p-about {
    display: grid;
    gap: 4rem;
    padding: 2rem 0 4rem;
  }
  .p-about__hero {
    text-align: center;
    max-width: 46rem;
    margin-inline: auto;
  }
  .p-about__eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.8rem;
    opacity: 0.65;
    margin: 0 0 0.75rem;
  }
  .p-about__headline {
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.05;
    margin: 0;
  }
  .p-about__sub {
    font-size: 1.2rem;
    opacity: 0.8;
    margin: 1rem 0 0;
  }
  .p-about__story {
    max-width: 40rem;
    margin-inline: auto;
  }
  .p-about__stats {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr));
    gap: 2rem;
    text-align: center;
  }
  .p-about__stat-value {
    display: block;
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1;
  }
  .p-about__stat-label {
    display: block;
    margin-top: 0.4rem;
    opacity: 0.7;
    font-size: 0.95rem;
  }
  .p-about__cta {
    text-align: center;
    padding: 2.5rem;
    border: 1px solid color-mix(in oklab, currentColor 15%, transparent);
    border-radius: 1rem;
  }
</style>
