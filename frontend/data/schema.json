  {
    "kind": "files",
    "name": "settings",
    "label": "Settings",
    "files": [
      {
        "name": "appearance",
        "label": "Appearance",
        "file": "frontend/data/appearance.json",
        "fields": [
          {
            "name": "theme",
            "label": "Site theme",
            "widget": "select",
            "options": [
              "freehold",
              "editorial",
              "magazine",
              "landing",
              "classic"
            ],
            "default": "freehold",
            "hint": "The public site's look. Per-entry Layout can still override the width."
          },
          {
            "name": "logo",
            "label": "Logo",
            "widget": "image",
            "required": false,
            "hint": "Shown in the site header in place of the text wordmark. Leave empty to use the site name."
          }
        ]
      },
      {
        "name": "seo_defaults",
        "label": "SEO defaults",
        "file": "frontend/data/seo.json",
        "localized": true,
        "fields": [
          {
            "name": "siteName",
            "label": "Site name",
            "widget": "string"
          },
          {
            "name": "titleTemplate",
            "label": "Title template",
            "widget": "string",
            "hint": "Use %s where the page title goes, e.g. '%s · My Site'"
          },
          {
            "name": "defaultTitle",
            "label": "Default title",
            "widget": "string"
          },
          {
            "name": "defaultDescription",
            "label": "Default description",
            "widget": "text"
          },
          {
            "name": "defaultOgImage",
