---
// Shared render for an author archive — used by the root route (/author/x/) and
// the localized mirror (/es/author/x/). Authors are shared (not localized); each
// archive lists the active locale's posts by them. Route files differ only in
// getStaticPaths.
import type { CollectionEntry } from "astro:content";
import Base from "../layouts/Base.astro";
import Archive from "./Archive.astro";
import { type Locale } from "../lib/i18n";
import { allLocaleAlternates } from "../lib/alternates";
import { localePosts } from "../lib/routing";

interface Props {
  author: CollectionEntry<"authors">;
  locale: Locale;
}

const { author, locale } = Astro.props;
const posts = await localePosts(locale, (data) => data.author === author.id);
const alternates = allLocaleAlternates(`author/${author.id}/`);
---

<Base
  locale={locale}
  alternates={alternates}
  seo={{ title: author.data.title, description: author.data.bio }}
>
  {author.data.avatar && <img src={author.data.avatar} alt={author.data.title} />}
  <Archive
    heading={author.data.title}
    locale={locale}
    posts={posts}
    description={author.data.bio}
    emptyText="No posts by this author yet."
  />
</Base>
