---
// /how-it-works — the dev/agent deep dive: the life of an edit, scroll-scrubbed.
// A sticky trajectory diagram on the left; scrolling stage panels on the right.
// A tiny IntersectionObserver lights the active node + fills the trajectory line
// as you scroll; with JS off or reduced-motion it degrades to a fully-readable
// stacked list (every node lit, every panel shown). Honest architecture — the
// real stack, named: your words → agent → git → GitHub → Cloudflare Pages
// (Astro) → global edge → Google + agents. Static + cacheable (inline is:inline
// script only). Bilingual. Rendered by pages/how-it-works.astro + en mirror.
import type { Locale } from "../lib/i18n";

interface Props {
  locale?: Locale;
}
const { locale = "es" } = Astro.props;
const isEn = locale === "en";
const base = isEn ? "/en" : "";

const es = {
  tag: "CÓMO FUNCIONA · SIN MAGIA",
  headline: "La vida de un cambio, de principio a fin.",
  sub: "Sin base de datos. Sin servidor. Sin ataduras. Su sitio es una carpeta de archivos en un repositorio suyo; un agente la edita y dos plataformas la sirven. Esto es todo lo que pasa.",
  stages: [
    { t: "Usted describe el cambio", code: "en lenguaje natural", b: "Le dice a un agente de IA qué quiere, en cualquier idioma. Sin sintaxis, sin panel de administración que aprender." },
    { t: "El agente edita el repositorio", code: "read schema.ts · write .md/.html", b: "El agente lee su modelo de contenido, edita los archivos correctos y guarda el cambio como un commit — igual que lo haría un programador." },
    { t: "GitHub guarda la versión", code: "git push origin main", b: "Su repositorio es la fuente de la verdad. Cada versión queda registrada y es reversible. El repositorio le pertenece: lléveselo cuando quiera." },
    { t: "Cloudflare Pages construye", code: "astro build", b: "Un build estático compila los archivos a HTML puro. Nada que ejecutar en producción, nada que hackear, nada que parchar." },
    { t: "El borde global lo sirve", code: "300+ ciudades · en caché", b: "Su sitio sale desde la red de Cloudflare, cerca de cada visitante. Las vistas de página no se miden — es rápido en todas partes y gratis." },
    { t: "Google y los agentes lo encuentran", code: "sitemap.xml · llms.txt", b: "Es un sitio real en la web abierta, con URLs reales, datos estructurados y un contrato para agentes. Se puede descubrir por diseño." },
  ],
  devEyebrow: "Para desarrolladores",
  devHead: "Es suyo hasta el último archivo.",
  devBody: "Astro + Git + Cloudflare Pages, todo en el plan gratuito. Sin base de datos que administrar, sin runtime que mantener. Bifúrquelo, alójelo usted mismo, conecte su propio agente al mismo modelo de contenido. Nada aquí le retiene.",
  devLink: "Leer el contrato para agentes",
  ctaHead: "¿Listo para lanzar?",
  ctaSub: "Vea lo que cuesta y empiece en unos 30 minutos.",
  cta: "Empezar",
};

const en = {
  tag: "HOW IT WORKS · NO MAGIC",
  headline: "The life of an edit, end to end.",
  sub: "No database. No server. No lock-in. Your site is a folder of files in a repository you own; an agent edits it and two platforms serve it. This is everything that happens.",
  stages: [
    { t: "You describe the change", code: "in plain language", b: "Tell an AI agent what you want, in any language. No syntax, no admin panel to learn." },
    { t: "The agent edits the repo", code: "read schema.ts · write .md/.html", b: "The agent reads your content model, edits the right files, and saves the change as a commit — exactly like a developer would." },
    { t: "GitHub stores the version", code: "git push origin main", b: "Your repository is the source of truth. Every version is recorded and reversible. The repo belongs to you: take it anywhere, any time." },
    { t: "Cloudflare Pages builds", code: "astro build", b: "A static build compiles the files to plain HTML. Nothing to run in production, nothing to hack, nothing to patch." },
    { t: "The global edge serves it", code: "300+ cities · cached", b: "Your site goes out from Cloudflare's network, close to every visitor. Page views are unmetered — fast everywhere, and free." },
    { t: "Google and agents find it", code: "sitemap.xml · llms.txt", b: "It's a real site on the open web, with real URLs, structured data, and a contract for agents. Discoverable by design." },
  ],
  devEyebrow: "For developers",
  devHead: "Yours down to the last file.",
  devBody: "Astro + Git + Cloudflare Pages, all on the free tier. No database to run, no runtime to keep alive. Fork it, self-host it, point your own agent at the same content model. Nothing here holds you in.",
  devLink: "Read the agent contract",
  ctaHead: "Ready to launch?",
  ctaSub: "See what it costs and start in about 30 minutes.",
  cta: "Start your site",
};

const t = isEn ? en : es;
---

<div class="hiw">
  <header class="hiw-head">
    <span class="hiw-tag">{t.tag}</span>
    <h1 class="hiw-headline">{t.headline}</h1>
    <p class="hiw-sub">{t.sub}</p>
  </header>

  <div class="hiw-scrolly">
    <!-- sticky trajectory diagram -->
    <aside class="hiw-stage" aria-hidden="true">
      <div class="hiw-diagram">
        <span class="hiw-diagram__track"></span>
        <span class="hiw-diagram__fill" data-hiw-fill></span>
        {t.stages.map((s, i) => (
          <span class="hiw-node is-lit" data-hiw-node style={`--i:${i}`}>
            <span class="hiw-node__dot"></span>
            <span class="hiw-node__t">{s.t}</span>
          </span>
        ))}
        <span class="hiw-diagram__arrow">↗</span>
      </div>
    </aside>

    <!-- scrolling stage panels -->
    <ol class="hiw-panels">
      {t.stages.map((s, i) => (
        <li class="hiw-panel" data-hiw-panel={i}>
          <div class="hiw-panel__inner">
            <span class="hiw-panel__num">{String(i + 1).padStart(2, "0")} / {String(t.stages.length).padStart(2, "0")}</span>
            <h2 class="hiw-panel__t">{s.t}</h2>
            <code class="hiw-panel__code">{s.code}</code>
            <p class="hiw-panel__b">{s.b}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>

  <!-- developer / agent callout -->
  <section class="hiw-band">
    <div class="hiw-wrap">
      <span class="hiw-eyebrow">{t.devEyebrow}</span>
      <h2 class="hiw-h2">{t.devHead}</h2>
      <p class="hiw-lede">{t.devBody}</p>
      <a class="hiw-link" href={`${base}/agents`}>{t.devLink}<span class="hiw-arrow" aria-hidden="true">↗</span></a>
    </div>
  </section>

  <section class="hiw-cta">
    <div class="hiw-wrap hiw-wrap--narrow">
      <h2 class="hiw-cta__head">{t.ctaHead}</h2>
      <p class="hiw-cta__sub">{t.ctaSub}</p>
      <a class="hiw-btn" href={`${base}/start`}>{t.cta}<span class="hiw-arrow" aria-hidden="true">↗</span></a>
    </div>
  </section>
</div>

<script is:inline>
  (function () {
    var panels = document.querySelectorAll("[data-hiw-panel]");
    var nodes = document.querySelectorAll("[data-hiw-node]");
    var fill = document.querySelector("[data-hiw-fill]");
    if (!panels.length || !("IntersectionObserver" in window)) return;
    var last = nodes.length - 1;
    var io = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (e) {
          if (!e.isIntersecting) return;
          var i = Number(e.target.getAttribute("data-hiw-panel"));
          nodes.forEach(function (n, j) {
            n.classList.toggle("is-lit", j <= i);
            n.classList.toggle("is-active", j === i);
          });
          if (fill) fill.style.setProperty("--fill", last ? i / last : 0);
        });
      },
      { rootMargin: "-45% 0px -45% 0px", threshold: 0 }
    );
    panels.forEach(function (p) {
      io.observe(p);
    });
  })();
</script>

<style>
  .hiw { color: var(--ink); font-family: var(--font-ui); }
  .hiw-wrap { max-width: var(--wide); margin: 0 auto; padding: 0 1.5rem; }
  .hiw-wrap--narrow { max-width: 60rem; }

  /* header */
  .hiw-head { max-width: var(--wide); margin: 0 auto; padding: clamp(3rem, 7vw, 5.5rem) 1.5rem clamp(1.5rem, 4vw, 3rem); }
  .hiw-tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    color: var(--accent);
    padding-bottom: 0.9rem;
    margin-bottom: 1.4rem;
    border-bottom: 1px solid var(--rule);
  }
  .hiw-headline {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(2.4rem, 5.4vw, 4.2rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
    margin: 0 0 1.2rem;
    max-width: 18ch;
    text-wrap: balance;
  }
  .hiw-sub { font-size: 1.16rem; line-height: 1.65; color: var(--text-secondary); max-width: 56ch; margin: 0; }

  /* scrolly layout */
  .hiw-scrolly {
    max-width: var(--wide);
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: start;
  }

  /* sticky diagram */
  .hiw-stage { position: sticky; top: 0; height: 100vh; display: flex; align-items: center; }
  .hiw-diagram { position: relative; width: 100%; padding-left: 1.5rem; }
  .hiw-diagram__track,
  .hiw-diagram__fill {
    position: absolute;
    left: 5px;
    top: 0.4rem;
    bottom: 2.2rem;
    width: 2px;
  }
  .hiw-diagram__track { background: var(--rule); }
  .hiw-diagram__fill {
    background: var(--accent);
    transform-origin: top;
    transform: scaleY(var(--fill, 0));
    transition: transform 420ms cubic-bezier(0.3, 0.7, 0.2, 1);
    bottom: auto;
    height: calc(100% - 2.6rem);
  }
  .hiw-node {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 0.8rem;
    padding: 0.85rem 0;
    margin-left: -1.5rem;
    padding-left: 1.5rem;
  }
  .hiw-node__dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--muted);
    transition: background 260ms ease, border-color 260ms ease, transform 260ms ease;
  }
  .hiw-node__t {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.02em;
    color: var(--muted);
    transition: color 260ms ease;
  }
  .hiw-node.is-lit .hiw-node__dot { border-color: var(--accent); }
  .hiw-node.is-lit .hiw-node__t { color: var(--text-secondary); }
  .hiw-node.is-active .hiw-node__dot { background: var(--accent); border-color: var(--accent); transform: scale(1.25); }
  .hiw-node.is-active .hiw-node__t { color: var(--ink); font-weight: 500; }
  .hiw-diagram__arrow {
    position: absolute;
    left: -1px;
    bottom: 0;
    font-size: 1.6rem;
    line-height: 1;
    color: var(--accent);
    font-weight: 600;
  }

  /* scrolling panels */
  .hiw-panels { list-style: none; margin: 0; padding: 0; }
  .hiw-panel { min-height: 82vh; display: flex; align-items: center; }
  .hiw-panel:last-child { min-height: 60vh; }
  .hiw-panel__inner {
    border-left: 3px solid var(--accent);
    padding: 0.4rem 0 0.4rem 1.6rem;
  }
  .hiw-panel__num { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.14em; color: var(--accent); }
  .hiw-panel__t {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(1.6rem, 3.4vw, 2.4rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin: 0.6rem 0 0.9rem;
    max-width: 16ch;
  }
  .hiw-panel__code {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-secondary);
    background: var(--surface);
    border: 1px solid var(--rule);
    border-radius: 2px;
    padding: 0.3rem 0.6rem;
    margin-bottom: 1.1rem;
  }
  .hiw-panel__b { font-size: 1.08rem; line-height: 1.65; color: var(--text-secondary); max-width: 44ch; margin: 0; }

  /* developer band */
  .hiw-band { background: var(--ink-deep); color: #f3f1ea; padding: clamp(3.5rem, 8vw, 6rem) 0; margin-top: clamp(2rem, 5vw, 4rem); }
  .hiw-eyebrow { display: inline-block; font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--accent-bright); margin-bottom: 1.1rem; }
  .hiw-h2 { font-family: var(--font-heading); font-weight: 600; font-size: clamp(1.9rem, 4vw, 3rem); line-height: 1.06; letter-spacing: -0.02em; color: #fff; margin: 0 0 1.2rem; max-width: 20ch; }
  .hiw-lede { font-size: 1.14rem; line-height: 1.7; color: #a8a199; max-width: 60ch; margin: 0 0 1.6rem; }
  .hiw-link { font-family: var(--font-mono); font-size: 0.76rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent-bright); text-decoration: none; }

  /* closing cta */
  .hiw-cta { background: var(--surface); padding: clamp(3.5rem, 8vw, 6rem) 0; text-align: center; }
  .hiw-cta__head { font-family: var(--font-heading); font-weight: 600; font-size: clamp(2rem, 5vw, 3.4rem); line-height: 1.02; letter-spacing: -0.02em; margin: 0 0 0.9rem; }
  .hiw-cta__sub { font-size: 1.12rem; color: var(--text-secondary); margin: 0 auto 1.8rem; max-width: 42ch; }
  .hiw-btn {
    display: inline-flex;
    align-items: center;
    background: var(--accent);
    color: var(--on-accent);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 1.05rem 2rem;
    border-radius: var(--radius);
    text-decoration: none;
    transition: transform 140ms ease, background 140ms ease;
  }
  .hiw-btn:hover { transform: translateY(-2px); background: var(--accent-bright); }

  .hiw-arrow { display: inline-block; margin-left: 0.4em; transition: transform 160ms ease; }
  .hiw-link:hover .hiw-arrow, .hiw-btn:hover .hiw-arrow { transform: translate(2px, -2px); }

  .hiw a:focus-visible, .hiw-btn:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }

  @media (prefers-reduced-motion: reduce) {
    .hiw-diagram__fill, .hiw-node__dot, .hiw-node__t, .hiw-arrow, .hiw-btn { transition: none; }
  }

  /* mobile: drop the sticky diagram, stack readable panels */
  @media (max-width: 820px) {
    .hiw-scrolly { grid-template-columns: 1fr; gap: 0; }
    .hiw-stage { display: none; }
    .hiw-panel { min-height: 0; padding: 1.6rem 0; }
    .hiw-panel:last-child { min-height: 0; }
  }
</style>
