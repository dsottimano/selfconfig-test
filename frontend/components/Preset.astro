---
// Page-template dispatcher. Resolves a page's `preset` name to a designed
// component in frontend/presets/ BY CONVENTION — `preset: "about"` renders
// presets/about.astro. Presets are self-contained (design + a co-located
// .slots.json describing their editable slots); nothing here enumerates them,
// so a tenant or an AI agent adds a preset by dropping in a file, no core edit.
//
// The preset owns the page: it receives the entry's freeform `slots` object and
// renders the whole design. See PageArticle.astro for where it's mounted.
interface Props {
  name: string;
  slots?: Record<string, unknown>;
}

const { name, slots = {} } = Astro.props;

// Eager glob so the map is resolved at build time (static site — no runtime import).
const presets = import.meta.glob<{ default: unknown }>("../presets/*.astro", {
  eager: true,
});
const mod = presets[`../presets/${name}.astro`];
const Preset = mod?.default as (props: { slots: Record<string, unknown> }) => unknown;
---

{
  Preset ? (
    <Preset slots={slots} />
  ) : (
    // Unknown/removed preset — never break the render; surface it plainly instead.
    <p class="preset-missing">Unknown template “{name}”.</p>
  )
}
