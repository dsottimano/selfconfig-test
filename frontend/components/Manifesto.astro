---
// The flagship default home — the Lanza wordmark identity (Ink/Paper + Jost +
// the launch accent). It sells one product to three audiences at once (normie,
// developer, AI agent) off a single spine: "the life of an edit" — you ask → it
// commits → it builds → it serves → you're found. Ownership / no-lock-in is the
// through-line. Bilingual (es default / en). Chrome-light: pages pass
// template="landing" so Base drops the nav; this carries its own language toggle
// + CTAs. Pure CSS/type, no images/JS — static, cacheable, asset-free. The deep
// dives live on /how-it-works (dev/agent parallax), /start (normie), /agents.
import type { Locale } from "../lib/i18n";

interface Props {
  locale?: Locale;
}
const { locale = "es" } = Astro.props;
const isEn = locale === "en";
const altHome = isEn ? "/" : "/en/";
const base = isEn ? "/en" : "";
const links = {
  how: `${base}/how-it-works`,
  start: `${base}/start`,
  agents: `${base}/agents`,
};

const es = {
  toggle: { here: "ES", there: "EN", label: "Idioma" },
  hero: {
    tag: "PUBLICAR EN LA WEB ABIERTA · TODO SUYO",
    headline: "Lance un sitio que de verdad es suyo.",
    sub: "Lanza (del español lanzar) le da una dirección real en la web abierta: una carpeta de archivos que le pertenece, alojada gratis en GitHub y Cloudflare, y modificable con solo pedírselo a un agente de IA. Sin plataforma, sin ataduras, sin programador.",
    cta1: "Empezar",
    cta2: "Cómo funciona",
  },
  demo: {
    youWho: "usted",
    you: "Agrega una página con mi menú y precios, y cambia el logo de la cabecera.",
    agentWho: "lanza",
    agent: "Listo — publicado en su-nombre.com. Google lo verá en un día.",
    caption: "Usted dice qué quiere. El agente edita el repositorio y publica.",
  },
  spine: {
    eyebrow: "La vida de un cambio",
    headline: "Entra una frase. Sale una página en vivo.",
    steps: [
      ["Usted lo pide", "lenguaje sencillo", "Le dice a un agente qué cambiar, en cualquier idioma."],
      ["Lo confirma", "git commit", "El agente edita su repositorio y guarda el cambio como un commit."],
      ["Lo construye", "cloudflare pages", "Cloudflare reconstruye su sitio a partir de esos archivos, solo."],
      ["Lo sirve", "red global", "Su página sale a una red que cubre el planeta — rápida en todas partes, gratis."],
      ["Le encuentran", "la web abierta", "Es un sitio real en la web abierta: Google y otros agentes lo encuentran."],
    ],
  },
  doors: {
    eyebrow: "Tres maneras de entrar",
    headline: "Hecho para quien tenga el teclado.",
    cards: [
      { who: "Solo quiere un sitio", body: "Sin código ni tecnicismos. Usted lo describe, aparece. Vea lo que cuesta y cómo empezar.", cta: "Empezar", href: "start" },
      { who: "Es desarrollador", body: "Es Astro + Git + Cloudflare Pages. Sin base de datos, sin servidor, sin ataduras. Bifúrquelo, alójelo usted, conecte su propio agente.", cta: "Ver el stack", href: "how" },
      { who: "Es un agente", body: "Un repositorio documentado que puede manejar: esquema, modelo de contenido y un contrato llms.txt. Opere el sitio de un humano en su nombre.", cta: "Leer el contrato", href: "agents" },
    ],
  },
  own: {
    eyebrow: "Lo que cuesta · lo que conserva",
    headline: "Gratis de mantener. Suyo para siempre.",
    body: "Se apoya en GitHub y Cloudflare — empresas serias cuyo plan gratuito es de verdad gratuito. La única factura es su dominio. Es código abierto y es una simple carpeta de archivos: expórtelo, bifúrquelo, alójelo usted mismo. Lo use como lo use, es suyo.",
    tiles: [
      ["$0", "construir, alojar y mantener"],
      ["~$12", "al año por su dominio — el único costo"],
      ["~30 min", "de cero a un sitio en vivo"],
    ],
  },
  close: {
    headline: "Lance su primera página.",
    sub: "Un rincón de la web abierta, en propiedad plena, está a una frase de distancia.",
    cta: "Empezar",
  },
};

const en = {
  toggle: { here: "EN", there: "ES", label: "Language" },
  hero: {
    tag: "OPEN-WEB PUBLISHING · YOURS OUTRIGHT",
    headline: "Launch a site you actually own.",
    sub: "Lanza (Spanish for throw) gives you a real address on the open web: a folder of files that belongs to you, hosted free on GitHub and Cloudflare, and changed just by asking an AI agent. No platform, no lock-in, no developer.",
    cta1: "Start your site",
    cta2: "How it works",
  },
  demo: {
    youWho: "you",
    you: "Add a page with my menu and prices, and swap the header logo.",
    agentWho: "lanza",
    agent: "Done — published to your-name.com. Google will see it within a day.",
    caption: "You say what you want. The agent edits the repo and publishes.",
  },
  spine: {
    eyebrow: "The life of an edit",
    headline: "One sentence in. A live page out.",
    steps: [
      ["You ask", "plain language", "Tell an agent what to change, in any language."],
      ["It commits", "git commit", "The agent edits your repository and saves the change as a commit."],
      ["It builds", "cloudflare pages", "Cloudflare rebuilds your site from those files, automatically."],
      ["It serves", "global edge", "Your page goes out on a network that spans the planet — fast everywhere, free."],
      ["You're found", "the open web", "It's a real site on the open web, so Google and other agents can find it."],
    ],
  },
  doors: {
    eyebrow: "Three ways in",
    headline: "Built for whoever's holding the keyboard.",
    cards: [
      { who: "You just want a site", body: "No code, no jargon. You describe it, it appears. See what it costs and how to start.", cta: "Get started", href: "start" },
      { who: "You're a developer", body: "It's Astro + Git + Cloudflare Pages. No database, no server, no lock-in. Fork it, self-host it, wire your own agent.", cta: "See the stack", href: "how" },
      { who: "You're an agent", body: "A documented repo you can drive: schema, content model, and an llms.txt contract. Operate a human's site on their behalf.", cta: "Read the contract", href: "agents" },
    ],
  },
  own: {
    eyebrow: "What it costs · what you keep",
    headline: "Free to run. Yours to keep.",
    body: "You stand on GitHub and Cloudflare — serious companies whose free tiers are genuinely free. The only bill is your domain. It's open source and it's a plain folder of files: export it, fork it, host it yourself. However you use it, it's yours.",
    tiles: [
      ["$0", "to build, host and run"],
      ["~$12", "a year for your domain — the only cost"],
      ["~30 min", "from zero to a live site"],
    ],
  },
  close: {
    headline: "Throw your first page.",
    sub: "A corner of the open web, owned outright, is one sentence away.",
    cta: "Start your site",
  },
};

const t = isEn ? en : es;
const hrefFor = (k: string) => (k === "start" ? links.start : k === "how" ? links.how : links.agents);
---

<div class="lz">
  <!-- ── Hero: the thesis ──────────────────────────────────────────────── -->
  <section class="lz-hero">
    <div class="lz-hero__grid">
      <div class="lz-hero__lede">
        <span class="lz-tag">{t.hero.tag}</span>
        <h1 class="lz-hero__headline">{t.hero.headline}</h1>
        <p class="lz-hero__sub">{t.hero.sub}</p>
        <div class="lz-hero__ctas">
          <a class="lz-btn lz-btn--accent" href={links.start}>{t.hero.cta1}</a>
          <a class="lz-btn lz-btn--ghost" href={links.how}>{t.hero.cta2}<span class="lz-arrow" aria-hidden="true">↗</span></a>
        </div>
        <a class="lz-lang" href={altHome} aria-label={t.toggle.label}>
          <span class="lz-lang__here">{t.toggle.here}</span>
          <span class="lz-lang__sep">→</span>
          <span class="lz-lang__there">{t.toggle.there}</span>
        </a>
      </div>

      <!-- the one-line ask → published exchange -->
      <div class="lz-demo" role="figure" aria-label={t.demo.caption}>
        <div class="lz-msg lz-msg--you">
          <span class="lz-msg__who">{t.demo.youWho}</span>
          <p class="lz-msg__text">{t.demo.you}</p>
        </div>
        <div class="lz-msg lz-msg--agent">
          <span class="lz-msg__who">{t.demo.agentWho}<span class="lz-live" aria-hidden="true"></span></span>
          <p class="lz-msg__text">{t.demo.agent}</p>
        </div>
        <p class="lz-demo__caption">{t.demo.caption}</p>
      </div>
    </div>
  </section>

  <!-- ── The spine: the life of an edit (the signature trajectory) ──────── -->
  <section class="lz-band lz-band--ink" id="how">
    <div class="lz-wrap">
      <span class="lz-eyebrow lz-eyebrow--onInk">{t.spine.eyebrow}</span>
      <h2 class="lz-h2 lz-h2--onInk">{t.spine.headline}</h2>
      <ol class="lz-spine">
        {t.spine.steps.map(([label, svc, body], i) => (
          <li class="lz-step">
            <span class="lz-step__dot" aria-hidden="true"></span>
            <span class="lz-step__num">{String(i + 1).padStart(2, "0")}</span>
            <h3 class="lz-step__label">{label}</h3>
            <code class="lz-step__svc">{svc}</code>
            <p class="lz-step__body">{body}</p>
          </li>
        ))}
        <span class="lz-spine__arrow" aria-hidden="true">↗</span>
      </ol>
    </div>
  </section>

  <!-- ── Three doors: the three audiences ──────────────────────────────── -->
  <section class="lz-band lz-band--paper">
    <div class="lz-wrap">
      <span class="lz-eyebrow">{t.doors.eyebrow}</span>
      <h2 class="lz-h2">{t.doors.headline}</h2>
      <div class="lz-doors">
        {t.doors.cards.map((c) => (
          <a class="lz-door" href={hrefFor(c.href)}>
            <h3 class="lz-door__who">{c.who}</h3>
            <p class="lz-door__body">{c.body}</p>
            <span class="lz-door__cta">{c.cta}<span class="lz-arrow" aria-hidden="true">↗</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Ownership + honest cost/time ──────────────────────────────────── -->
  <section class="lz-band lz-band--surface">
    <div class="lz-wrap lz-wrap--narrow">
      <span class="lz-eyebrow">{t.own.eyebrow}</span>
      <h2 class="lz-h2">{t.own.headline}</h2>
      <p class="lz-lede">{t.own.body}</p>
      <div class="lz-tiles">
        {t.own.tiles.map(([n, l]) => (
          <div class="lz-tile">
            <span class="lz-tile__n">{n}</span>
            <span class="lz-tile__l">{l}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Close ─────────────────────────────────────────────────────────── -->
  <section class="lz-band lz-band--ink lz-close">
    <div class="lz-wrap lz-wrap--narrow">
      <h2 class="lz-close__headline">{t.close.headline}</h2>
      <p class="lz-close__sub">{t.close.sub}</p>
      <a class="lz-btn lz-btn--accent lz-btn--lg" href={links.start}>{t.close.cta}<span class="lz-arrow" aria-hidden="true">↗</span></a>
    </div>
  </section>
</div>

<style>
  .lz {
    color: var(--ink);
    font-family: var(--font-ui);
    --lz-onInk: #f3f1ea;
    --lz-onInk-dim: #a8a199;
  }

  /* shared */
  .lz-wrap { max-width: var(--wide); margin: 0 auto; padding: 0 1.5rem; }
  .lz-wrap--narrow { max-width: 62rem; }
  .lz-band { padding: clamp(3.5rem, 8vw, 6.5rem) 0; }
  .lz-band--paper { background: var(--paper); }
  .lz-band--surface { background: var(--surface); }
  .lz-band--ink { background: var(--ink-deep); color: var(--lz-onInk); }

  .lz-eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.1rem;
  }
  .lz-eyebrow--onInk { color: var(--accent-bright); }
  .lz-h2 {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(1.9rem, 4vw, 3rem);
    line-height: 1.06;
    letter-spacing: -0.02em;
    margin: 0 0 1.2rem;
    max-width: 20ch;
  }
  .lz-h2--onInk { color: #fff; }
  .lz-lede {
    font-size: 1.14rem;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 62ch;
    margin: 0 0 2.4rem;
  }

  /* the ↗ inline arrow — the launch mark, always accent */
  .lz-arrow {
    display: inline-block;
    margin-left: 0.4em;
    color: var(--accent);
    font-weight: 600;
    transition: transform 160ms ease;
  }
  .lz-btn--accent .lz-arrow { color: var(--on-accent); }

  /* buttons */
  .lz-btn {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.9rem 1.5rem;
    text-decoration: none;
    border: 1px solid transparent;
    border-radius: var(--radius);
    transition: transform 140ms ease, background 140ms ease, color 140ms ease, border-color 140ms ease;
  }
  .lz-btn--accent { background: var(--accent); color: var(--on-accent); }
  .lz-btn--accent:hover { transform: translateY(-2px); background: var(--accent-bright); }
  .lz-btn--ghost { background: transparent; color: var(--ink); border-color: var(--border); }
  .lz-band--ink .lz-btn--ghost { color: var(--lz-onInk); border-color: rgba(243,241,234,0.3); }
  .lz-btn--ghost:hover { border-color: var(--accent); color: var(--accent); }
  .lz-btn:hover .lz-arrow { transform: translate(2px, -2px); }
  .lz-btn--lg { padding: 1.05rem 2rem; font-size: 0.8rem; }

  /* ── Hero ─────────────────────────────────────────────────────────── */
  .lz-hero { background: var(--paper); padding: clamp(3rem, 7vw, 6rem) 0 clamp(3.5rem, 8vw, 6rem); overflow: hidden; }
  .lz-hero__grid {
    max-width: var(--wide);
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }
  .lz-tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    color: var(--accent);
    padding-bottom: 0.9rem;
    margin-bottom: 1.4rem;
    border-bottom: 1px solid var(--rule);
  }
  .lz-hero__headline {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(2.7rem, 6vw, 4.7rem);
    line-height: 1.0;
    letter-spacing: -0.03em;
    margin: 0 0 1.3rem;
    color: var(--ink);
    text-wrap: balance;
  }
  .lz-hero__sub {
    font-size: 1.14rem;
    line-height: 1.65;
    color: var(--text-secondary);
    max-width: 48ch;
    margin: 0 0 2rem;
  }
  .lz-hero__ctas { display: flex; gap: 0.9rem; flex-wrap: wrap; }
  .lz-lang {
    display: inline-flex;
    gap: 0.5rem;
    align-items: center;
    margin-top: 2.2rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-decoration: none;
    color: var(--muted);
  }
  .lz-lang__here { color: var(--ink); }
  .lz-lang:hover .lz-lang__there { color: var(--accent); }

  /* the ask → published exchange */
  .lz-demo {
    display: grid;
    gap: 0.7rem;
    background: var(--paper-card);
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    padding: 1.4rem 1.4rem 1.2rem;
    box-shadow: 0 24px 48px -30px rgba(0,0,0,0.4);
  }
  .lz-msg {
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    padding: 0.85rem 1rem;
    max-width: 92%;
  }
  .lz-msg--you { justify-self: end; background: var(--surface); }
  .lz-msg--agent { justify-self: start; background: color-mix(in srgb, var(--accent) 8%, transparent); border-color: color-mix(in srgb, var(--accent) 35%, transparent); }
  .lz-msg__who {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.4rem;
  }
  .lz-msg--agent .lz-msg__who { color: var(--accent); }
  .lz-live {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }
  .lz-msg__text { margin: 0; font-size: 0.98rem; line-height: 1.5; color: var(--ink); }
  .lz-demo__caption {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    line-height: 1.55;
    color: var(--muted);
    margin: 0.4rem 0 0;
  }

  /* ── Spine: the life of an edit ───────────────────────────────────── */
  .lz-spine {
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
    position: relative;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
  }
  /* the trajectory wire */
  .lz-spine::before {
    content: "";
    position: absolute;
    top: 5px;
    left: 0;
    right: 2.2rem;
    height: 2px;
    background: linear-gradient(90deg, color-mix(in srgb, var(--accent) 30%, transparent), var(--accent));
  }
  .lz-step { position: relative; padding: 1.6rem 1.2rem 0 0; }
  .lz-step__dot {
    position: absolute;
    top: 0;
    left: 0;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 4px var(--ink-deep);
  }
  .lz-step__num {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    color: var(--accent-bright);
  }
  .lz-step__label {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.25rem;
    line-height: 1.12;
    margin: 0.5rem 0 0.5rem;
    color: #fff;
  }
  .lz-step__svc {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.02em;
    color: var(--lz-onInk-dim);
    background: rgba(243,241,234,0.06);
    padding: 0.2rem 0.5rem;
    border-radius: 2px;
    margin-bottom: 0.8rem;
  }
  .lz-step__body { font-size: 0.9rem; line-height: 1.55; color: var(--lz-onInk-dim); margin: 0; }
  .lz-spine__arrow {
    position: absolute;
    top: -0.7rem;
    right: 0;
    font-size: 1.8rem;
    line-height: 1;
    color: var(--accent);
    font-weight: 600;
  }

  /* ── Three doors ──────────────────────────────────────────────────── */
  .lz-doors {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .lz-door {
    display: flex;
    flex-direction: column;
    background: var(--paper-card);
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    padding: 1.7rem 1.5rem;
    text-decoration: none;
    color: var(--ink);
    transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
  }
  .lz-door:hover {
    transform: translateY(-3px);
    border-color: var(--accent);
    box-shadow: 0 18px 36px -24px rgba(0,0,0,0.35);
  }
  .lz-door__who {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.3rem;
    line-height: 1.15;
    margin: 0 0 0.7rem;
  }
  .lz-door__body { font-size: 0.95rem; line-height: 1.6; color: var(--text-secondary); margin: 0 0 1.3rem; flex: 1; }
  .lz-door__cta {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .lz-door:hover .lz-arrow { transform: translate(2px, -2px); }

  /* ── Tiles (cost / time) ──────────────────────────────────────────── */
  .lz-tiles { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  .lz-tile {
    border: 1px solid var(--rule);
    border-left: 3px solid var(--accent);
    background: var(--paper-card);
    border-radius: var(--radius);
    padding: 1.6rem 1.4rem;
    display: grid;
    gap: 0.5rem;
  }
  .lz-tile__n {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 2.6rem;
    line-height: 1;
    color: var(--ink);
    letter-spacing: -0.02em;
  }
  .lz-tile__l { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.04em; color: var(--text-secondary); line-height: 1.45; }

  /* ── Close ────────────────────────────────────────────────────────── */
  .lz-close { text-align: center; }
  .lz-close__headline {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(2.6rem, 6vw, 4.4rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: #fff;
    margin: 0 0 1rem;
  }
  .lz-close__sub { font-size: 1.14rem; line-height: 1.6; color: var(--lz-onInk-dim); max-width: 46ch; margin: 0 auto 2rem; }

  /* page-load reveal — one orchestrated moment, motion-safe only */
  @media (prefers-reduced-motion: no-preference) {
    .lz-hero__lede > *, .lz-demo {
      animation: lz-rise 640ms cubic-bezier(0.2, 0.7, 0.2, 1) both;
    }
    .lz-hero__headline { animation-delay: 60ms; }
    .lz-hero__sub { animation-delay: 120ms; }
    .lz-hero__ctas { animation-delay: 180ms; }
