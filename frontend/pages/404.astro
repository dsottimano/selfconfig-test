---
import Base from "../layouts/Base.astro";
---

<Base seo={{ title: "404", noindex: true }}>
  <main class="notfound">
    <span class="u-kicker">Error 404</span>
    <h1>Página no encontrada</h1>
    <p>La página que busca no existe o fue movida.</p>
    <a class="u-btn" href="/">Volver al inicio</a>
  </main>
</Base>

<style>
  .notfound { text-align: center; padding: 6rem 1.25rem; display: flex; flex-direction: column; align-items: center; gap: 1rem; }
  .notfound h1 { margin: 0.3rem 0 0.4rem; }
  .notfound p { color: var(--text-secondary); margin: 0 0 1rem; }
</style>
