---
import PagePage from "../components/PagePage.astro";
import { DEFAULT_LOCALE } from "../lib/i18n";
import { publishedPages } from "../lib/routing";
import { splitEntries } from "../lib/paths";

// Standalone Pages (About, Contact, …) render at /<slug>. Static paths only —
// this is not a runtime catch-all; getStaticPaths emits exactly the page slugs.
// Default-locale (EN) only; ES/FR pages come from [locale]/[...slug].astro.
export async function getStaticPaths() {
  const { root } = splitEntries(await publishedPages());
  return root.map(({ entry, slug }) => ({ params: { slug }, props: { page: entry } }));
}

const { page } = Astro.props;
---

<PagePage page={page} locale={DEFAULT_LOCALE} />
