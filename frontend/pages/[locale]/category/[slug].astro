---
import { getCollection } from "astro:content";
import CategoryPage from "../../../components/CategoryPage.astro";
import { splitEntries } from "../../../lib/paths";

// Localized category archives (/es/category/x/). Non-default locales only.
export async function getStaticPaths() {
  const { localized } = splitEntries(await getCollection("categories"));
  return localized.map(({ entry, locale, slug }) => ({
    params: { locale, slug },
    props: { category: entry, locale },
  }));
}

const { category, locale } = Astro.props;
---

<CategoryPage category={category} locale={locale} />
