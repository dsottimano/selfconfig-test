---
import HomePage from "../../components/HomePage.astro";
import { otherLocales } from "../../lib/paths";

// Localized homepage (/es/, /fr/). One per non-default locale.
export async function getStaticPaths() {
  return otherLocales().map((locale) => ({ params: { locale }, props: { locale } }));
}

const { locale } = Astro.props;
---

<HomePage locale={locale} />
