---
import { getCollection } from "astro:content";
import AuthorPage from "../../../components/AuthorPage.astro";
import { otherLocales } from "../../../lib/paths";

// Localized author archives (/es/author/x/). Authors are shared (not localized),
// so we emit each author under every non-default locale, listing that locale's
// posts by them.
export async function getStaticPaths() {
  const authors = await getCollection("authors");
  return authors.flatMap((author) =>
    otherLocales().map((locale) => ({
      params: { locale, slug: author.id },
      props: { author, locale },
    })),
  );
}

const { author, locale } = Astro.props;
---

<AuthorPage author={author} locale={locale} />
