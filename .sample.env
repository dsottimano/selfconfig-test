GITHUB_TOKEN=

# Cloudflare API access for the CMS Site Health / provisioning diagnostics. In prod
# these are Cloudflare Pages runtime secrets; for local dev the CMS reads them from
# admin/.env (see admin/.sample.env for the token scopes). Mirrored here for
# reference — the dev Cloudflare proxy loads them from admin/.env.
# Minimal token scopes: Workers KV Storage:Edit, D1:Edit, Workers R2 Storage:Edit,
# Cloudflare Pages:Edit.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
PAGES_PROJECT=
